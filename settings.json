{
  "model": "opus[1m]",
  "permissions": {
    "allow": ["Bash"],
    "ask": [
      "Bash(git reset --hard:*)", "Bash(git clean:*)",
      "Bash(git checkout -- :*)", "Bash(git restore:*)",
      "Bash(git rebase:*)", "Bash(git branch -D:*)",
      "Bash(git push --force:*)", "Bash(git push -f:*)",
      "Bash(git rm:*)", "Bash(git filter-branch:*)",
      "Bash(rm -rf:*)", "Bash(dd:*)", "Bash(shred:*)", "Bash(truncate:*)",
      "Bash(chmod -R:*)", "Bash(chown -R:*)",
      "Bash(gh auth:*)", "Bash(npm login:*)",
      "Bash(ssh-keygen:*)", "Bash(ssh-add:*)", "Bash(gpg:*)",
      "Bash(ssh:*)", "Bash(scp:*)",
      "Bash(gh pr create:*)", "Bash(gh pr merge:*)",
      "Bash(npm publish:*)", "Bash(cargo publish:*)"
    ],
    "deny": []
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "armarium@hortus": true
  },
  "extraKnownMarketplaces": {
    "semgrep-marketplace": {
      "source": {
        "source": "github",
        "repo": "semgrep/mcp-marketplace"
      }
    },
    "hortus": {
      "source": {
        "source": "github",
        "repo": "Olbbemi/Armarium"
      }
    }
  },
  "theme": "dark",
  "tui": "fullscreen",
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-global-config.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/guard-bash.sh"
          }
        ]
      }
    ]
  }
}
